# =====================================================================
#  Streamlit Secrets Example File  —  Save as secrets.toml
#  Streamlit auto-ignores secrets.toml from source control
# =====================================================================

# ── Google OAuth (for "Sign in with Google") ──────────────────────
GOOGLE_CLIENT_ID     = "your-google-oauth-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET = "your-google-oauth-client-secret"
GOOGLE_REDIRECT_URI  = "http://localhost:8501"  # Or your deployment domain

# ── AI Provider API Keys ──────────────────────────────────────────
GEMINI_API_KEY      = "your-gemini-api-key"
GROQ_API_KEY        = "your-groq-api-key"
BazaarLink          = "your-bazaarlink-api-key"

# ── Fallback Admin Account ────────────────────────────────────────
LOGIN_USERNAME = "admin"
LOGIN_PASSWORD = "suvansh123"

# ── MySQL Database (Local development fallback) ────────────────────
MYSQL_HOST     = "127.0.0.1"
MYSQL_PORT     = "3306"
MYSQL_USER     = "root"
MYSQL_PASSWORD = ""
MYSQL_DATABASE = "ai_chatbot_db"

# ── MySQL Database (Remote Aiven configuration template) ───────────
# If deploying to Streamlit Cloud, copy these lines into your dashboard secrets:
# MYSQL_HOST        = "mysql-xxxxxx.aivencloud.com"
# MYSQL_PORT        = "26250"
# MYSQL_USER        = "avnadmin"
# MYSQL_PASSWORD    = "your-aiven-password"
# MYSQL_DATABASE    = "defaultdb"
# MYSQL_SSL_CA      = """-----BEGIN CERTIFICATE-----
# YOUR_AIVEN_CA_PEM_CERTIFICATE_CONTENT_HERE
# -----END CERTIFICATE-----"""
# MYSQL_SSL_VERIFY  = false

# ── Notion Export (for "Export to Notion" feature) ────────────────
# 1. Go to https://www.notion.so/my-integrations and create a new integration.
# 2. Copy the "Internal Integration Token" (starts with "secret_").
# 3. Open the Notion page you want chats exported under, click ⋯ > Connections,
#    and add your integration so it has access to that page.
# 4. Copy the page ID from the URL: notion.so/<workspace>/<PAGE_ID>
NOTION_TOKEN           = "secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
NOTION_PARENT_PAGE_ID  = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
